/* INPUTS */
QLineEdit {
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    padding: 10px;
    font-size: 14px;
    background-color: #fafafa;
}

QLineEdit:focus {
    border: 1px solid #3f4a2f;
    background-color: white;
}

/* BOTÃO LOGIN */
QPushButton#btn_login {
    background-color: rgb(63, 74, 47);
    color: white;
    border-radius: 12px;
    font-size: 14px;
    font-weight: bold;
    padding: 10px;
}

QPushButton#btn_login:hover {
    background-color: rgb(46, 55, 35);
}

QPushButton#btn_login:pressed {
    background-color: rgb(31, 37, 24);
}

/* CARD */
QFrame#loginCard {
    background-color: white;
    border-radius: 15px;
}

