             <string notr="true">QTableWidget#tableProducao {
    background-color: white;
    border: 2px solid #3F4A2F;
    border-radius: 10px;
    gridline-color: #3F4A2F;

    alternate-background-color: #F0F0F0;
    selection-background-color: #3F4A2F;
    selection-color: #E6D2A2;

    font-size: 12px;
    color: #2E3723;
}

/* Espaçamento interno das células */
QTableWidget#tableProducao::item {
    padding: 6px;
}

/* Hover (quando passa o mouse) */
QTableWidget#tableProducao::item:hover {
    background-color: #E6D2A2;
    color: #3F4A2F;
}

/* Linha selecionada */
QTableWidget#tableProducao::item:selected {
    background-color: #3F4A2F;
    color: #E6D2A2;
}

/* Cabeçalho */
QTableWidget#tableProducao QHeaderView::section {
    background-color: #3F4A2F;
    color: #E6D2A2;
    padding: 8px;
    border: none;
    font-weight: bold;
}

/* Hover no cabeçalho */
QTableWidget#tableProducao QHeaderView::section:hover {
    background-color: #2E3723;
}

/* Remove borda feia de foco */
QTableWidget#tableProducao {
    outline: none;
}

/* Scrollbar vertical */
QScrollBar:vertical {
    background: #F5F5F5;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #3F4A2F;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #2E3723;
}

/* Scrollbar horizontal */
QScrollBar:horizontal {
    background: #F5F5F5;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #3F4A2F;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background: #2E3723;
}</string>
