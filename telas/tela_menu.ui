          <item>
           <widget class="QTableWidget" name="tableWidgetFornecedores">
            <property name="styleSheet">
             <string notr="true">QMainWindow { background-color: #F5F5F5; }
QPushButton { background-color: #3F4A2F; color: #E6D2A2; border-radius: 10px; padding: 8px; font-weight: bold; }

QPushButton:hover { background-color: #2E3723; }

QLineEdit, QTextEdit, QComboBox, QDateEdit { border: 2px solid #3F4A2F; border-radius: 8px; padding: 5px; background-color: white; }

QGroupBox { border: 2px solid #3F4A2F; border-radius: 10px; margin-top: 10px; font-weight: bold; }

QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 5px; color: #3F4A2F; }

QTableView { background-color: white; border-radius: 10px; }

QTableWidget {
    background-color: white;
    gridline-color: #3F4A2F;
    border: 2px solid #3F4A2F;
    border-radius: 10px;
    selection-background-color: #3F4A2F;
    selection-color: #E6D2A2;
    font-size: 12px;
    alternate-background-color: #F0F0F0;
}

QTableWidget::item {
    padding: 6px;
}

QTableWidget::item:selected {
    background-color: #3F4A2F;
    color: #E6D2A2;
}

QTableWidget QHeaderView::section {
    background-color: #3F4A2F;
    color: #E6D2A2;
