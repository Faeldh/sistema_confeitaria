         <item><widget class="QPushButton" name="btnVendas"><property name="text"><string>Vendas</string></property></widget></item>
         <item><widget class="QPushButton" name="btnFornecedores"><property name="text"><string>Fornecedores</string></property></widget></item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>

    <!-- STACK -->
    <item>
     <widget class="QStackedWidget" name="stackedWidget">

      <!-- CLIENTES -->
      <widget class="QWidget" name="pageClientes">
       <layout class="QHBoxLayout">

        <!-- FORMULÁRIO ESQUERDA -->
        <item>
         <widget class="QGroupBox" name="groupBoxClientes">
          <property name="title"><string>Cadastro de Clientes</string></property>
          <layout class="QFormLayout">
           <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Nome:</string></property></widget></item>
           <item row="0" column="1"><widget class="QLineEdit"/></item>
           <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Telefone:</string></property></widget></item>
           <item row="1" column="1"><widget class="QLineEdit"/></item>
