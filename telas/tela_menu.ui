<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle">
   <string>Mira Confeitaria</string>
  </property>
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>700</height>
   </rect>
  </property>
  <property name="styleSheet">
   <string>
QMainWindow { background-color: #F5F5F5; }
QPushButton { background-color: #3F4A2F; color: #E6D2A2; border-radius: 10px; padding: 8px; font-weight: bold; }
QPushButton:hover { background-color: #2E3723; }
QLineEdit, QTextEdit, QComboBox, QDateEdit { border: 2px solid #3F4A2F; border-radius: 8px; padding: 5px; background-color: white; }
QGroupBox { border: 2px solid #3F4A2F; border-radius: 10px; margin-top: 10px; font-weight: bold; }
QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 5px; color: #3F4A2F; }
QTableView { background-color: white; border-radius: 10px; }
   </string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout">

    <!-- HEADER -->
    <item>
     <widget class="QWidget" name="headerWidget">
      <layout class="QHBoxLayout">
       <item>
        <widget class="QLabel" name="labelLogo">
         <property name="text"><string></string></property>
         <property name="styleSheet"><string>border: 1px dashed #3F4A2F; min-width:80px; min-height:60px;</string></property>
         <property name="alignment"><set>Qt::AlignCenter</set></property>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout">
         <item><widget class="QPushButton" name="btnClientes"><property name="text"><string>Clientes</string></property></widget></item>
         <item><widget class="QPushButton" name="btnPedidos"><property name="text"><string>Pedidos</string></property></widget></item>
         <item><widget class="QPushButton" name="btnReceitas"><property name="text"><string>Receitas</string></property></widget></item>
