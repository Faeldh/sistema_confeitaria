           <item row="2" column="1"><widget class="QDateEdit"/></item>
           <item row="3" column="0"><widget class="QLabel"><property name="text"><string>CEP:</string></property></widget></item>
           <item row="3" column="1"><widget class="QLineEdit"/></item>
           <item row="4" column="0"><widget class="QLabel"><property name="text"><string>Rua:</string></property></widget></item>
           <item row="4" column="1"><widget class="QLineEdit"/></item>
           <item row="5" column="0"><widget class="QLabel"><property name="text"><string>Bairro:</string></property></widget></item>
           <item row="5" column="1"><widget class="QLineEdit"/></item>
           <item row="6" column="0"><widget class="QLabel"><property name="text"><string>Nº:</string></property></widget></item>
           <item row="6" column="1"><widget class="QLineEdit"/></item>
           <item row="7" column="0"><widget class="QLabel"><property name="text"><string>Complemento:</string></property></widget></item>
           <item row="7" column="1"><widget class="QLineEdit"/></item>
           <item row="8" column="0"><widget class="QLabel"><property name="text"><string>Cidade:</string></property></widget></item>
           <item row="8" column="1"><widget class="QLineEdit"/></item>
           <item row="9" column="0"><widget class="QLabel"><property name="text"><string>E-mail:</string></property></widget></item>
           <item row="9" column="1"><widget class="QLineEdit"/></item>
           <item row="10" column="0"><widget class="QLabel"><property name="text"><string>Observações:</string></property></widget></item>
           <item row="10" column="1"><widget class="QTextEdit"/></item>
           <item row="11" column="0"><widget class="QPushButton"><property name="text"><string>Salvar</string></property></widget></item>
           <item row="11" column="1"><widget class="QPushButton"><property name="text"><string>Editar</string></property></widget></item>
           <item row="12" column="0"><widget class="QPushButton"><property name="text"><string>Excluir</string></property></widget></item>
